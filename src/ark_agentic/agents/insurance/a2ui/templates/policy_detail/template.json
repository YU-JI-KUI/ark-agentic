        }
      }
    },
    {
      "id": "val-total",
      "component": {
        "Text": {
          "text": { "path": "total_value" },
          "color": "#FF6600",
          "fontSize": "14px",
          "bold": true
        }
      }
    },
    {
      "id": "card-prompt",
      "component": {
        "Card": {
          "width": 100,
          "backgroundColor": "#FFFFFF",
          "borderRadius": "middle",
          "padding": 16,
          "children": { "explicitList": ["prompt-text"] }
        }
      }
    },
    {
      "id": "prompt-text",
      "component": {
        "Text": {
          "text": { "path": "prompt_text" },
          "color": "#666666",
          "fontSize": "14px"
        }
      }
    }
  ]
