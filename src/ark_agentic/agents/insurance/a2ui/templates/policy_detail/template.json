{
  "event": "beginRendering",
  "version": "1.0.0",
  "surfaceId": "",
  "rootComponentId": "root",
  "style": "default",
  "hideVoteRecorder": true,
  "data": {},
  "components": [
    {
      "id": "root",
      "component": {
        "Column": {
          "width": 100,
          "backgroundColor": "#F5F5F5",
          "padding": [16, 32, 16, 16],
          "gap": 16,
          "children": {
            "explicitList": [
              "card-title",
              "policy-list",
              "card-prompt"
            ]
          }
        }
      }
    },
    {
      "id": "card-title",
      "component": {
        "Card": {
          "width": 100,
          "backgroundColor": "#FFFFFF",
          "borderRadius": "middle",
          "padding": 16,
          "children": { "explicitList": ["page-title"] }
        }
      }
    },
    {
      "id": "page-title",
      "component": {
        "Text": {
          "text": { "path": "page_title" },
          "color": "#333333",
          "fontSize": "18px",
          "bold": true
        }
      }
    },
    {
      "id": "policy-list",
      "component": {
        "List": {
          "direction": "vertical",
          "gap": 16,
          "child": "policy-card-tpl",
          "dataSource": { "path": "policies" },
          "emptyChild": "empty-hint"
        }
      }
    },
    {
      "id": "empty-hint",
      "component": {
        "Text": {
          "text": { "literalString": "暂无保单信息" },
          "color": "#999999",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "policy-card-tpl",
      "component": {
        "Card": {
          "width": 100,
          "backgroundColor": "#FFFFFF",
          "borderRadius": "middle",
          "padding": 16,
          "children": { "explicitList": ["policy-col"] }
        }
      }
    },
    {
      "id": "policy-col",
      "component": {
        "Column": {
          "gap": 8,
          "children": {
            "explicitList": [
              "row-title",
              "meta-info-col",
              "divider-top",
              "row-survival",
              "row-bonus",
              "row-loan",
              "row-refund",
              "divider-total",
              "row-total"
            ]
          }
        }
      }
    },
    {
      "id": "row-title",
      "component": {
        "Row": {
          "alignment": "middle",
          "gap": 8,
          "children": { "explicitList": ["line-marker", "title-text"] }
        }
      }
    },
    {
      "id": "line-marker",
      "component": {
        "Text": {
          "text": { "literalString": "|" },
          "color": "#FF6600",
          "fontSize": "16px",
          "bold": true
        }
      }
    },
    {
      "id": "title-text",
      "component": {
        "Text": {
          "text": { "path": "title" },
          "color": "#333333",
          "fontSize": "16px",
          "bold": true
        }
      }
    },
    {
      "id": "meta-info-col",
      "component": {
        "Column": {
          "gap": 4,
          "children": {
            "explicitList": ["text-subtitle", "text-year"]
          }
        }
      }
    },
    {
      "id": "text-subtitle",
      "component": {
        "Text": {
          "text": { "path": "subtitle" },
          "color": "#999999",
          "fontSize": "12px"
        }
      }
    },
    {
      "id": "text-year",
      "component": {
        "Text": {
          "text": { "path": "year" },
          "color": "#999999",
          "fontSize": "12px"
        }
      }
    },
    {
      "id": "divider-top",
      "component": {
        "Divider": { "borderColor": "#F5F5F5", "hairline": true }
      }
    },
    {
      "id": "row-survival",
      "component": {
        "Row": {
          "width": 100,
          "distribution": "spaceBetween",
          "children": { "explicitList": ["lbl-survival", "val-survival"] }
        }
      }
    },
    {
      "id": "lbl-survival",
      "component": {
        "Text": {
          "text": { "path": "survival_label" },
          "color": "#666666",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "val-survival",
      "component": {
        "Text": {
          "text": { "path": "survival_value" },
          "color": "#333333",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "row-bonus",
      "component": {
        "Row": {
          "width": 100,
          "distribution": "spaceBetween",
          "children": { "explicitList": ["lbl-bonus", "val-bonus"] }
        }
      }
    },
    {
      "id": "lbl-bonus",
      "component": {
        "Text": {
          "text": { "path": "bonus_label" },
          "color": "#666666",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "val-bonus",
      "component": {
        "Text": {
          "text": { "path": "bonus_value" },
          "color": "#333333",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "row-loan",
      "component": {
        "Row": {
          "width": 100,
          "distribution": "spaceBetween",
          "children": { "explicitList": ["lbl-loan", "val-loan"] }
        }
      }
    },
    {
      "id": "lbl-loan",
      "component": {
        "Text": {
          "text": { "path": "loan_label" },
          "color": "#666666",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "val-loan",
      "component": {
        "Text": {
          "text": { "path": "loan_value" },
          "color": "#333333",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "row-refund",
      "component": {
        "Row": {
          "width": 100,
          "distribution": "spaceBetween",
          "children": { "explicitList": ["lbl-refund", "val-refund"] }
        }
      }
    },
    {
      "id": "lbl-refund",
      "component": {
        "Text": {
          "text": { "path": "refund_label" },
          "color": "#666666",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "val-refund",
      "component": {
        "Text": {
          "text": { "path": "refund_value" },
          "color": "#333333",
          "fontSize": "14px"
        }
      }
    },
    {
      "id": "divider-total",
      "component": {
        "Divider": { "borderColor": "#F5F5F5", "hairline": true }
      }
    },
    {
      "id": "row-total",
      "component": {
        "Row": {
          "width": 100,
          "distribution": "spaceBetween",
          "children": { "explicitList": ["lbl-total", "val-total"] }
        }
      }
    },
    {
      "id": "lbl-total",
      "component": {
        "Text": {
          "text": { "path": "total_label" },
          "color": "#333333",
          "fontSize": "14px",
