{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI: ark-agentic",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "ark_agentic.app:app",
                "--host", "0.0.0.0",
                "--port", "8080",
                "--reload", "false"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "jinja2": true,
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        }
    ]
}