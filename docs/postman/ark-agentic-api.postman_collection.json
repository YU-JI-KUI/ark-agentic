{
  "info": {
    "name": "ark-agentic-api",
    "description": "Ark-Agentic 统一 Agent API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "session_id",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "test-user-001"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Chat (non-stream)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"我想取点钱\",\n  \"stream\": false,\n  \"user_id\": \"{{user_id}}\",\n  \"context\": {\n    \"channel\": \"mobile_app\",\n    \"customer_tier\": \"vip\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        }
      }
    },
    {
      "name": "Chat (non-stream with headers)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-ark-user-id",
            "value": "{{user_id}}"
          },
          {
            "key": "x-ark-trace-id",
            "value": "trace-{{$randomUUID}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"查询我的保单信息\",\n  \"stream\": false,\n  \"context\": {\n    \"source\": \"postman_test\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        }
      }
    },
    {
      "name": "Chat (SSE stream - internal)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"我想取点钱\",\n  \"stream\": true,\n  \"protocol\": \"internal\",\n  \"user_id\": \"{{user_id}}\",\n  \"context\": {\n    \"channel\": \"web\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "SSE 流式响应，使用 legacy internal 协议（response.* 事件），适配现有前端：\\n- response.created / response.step / response.step.done\\n- response.content.delta\\n- response.completed / response.failed"
      }
    },
    {
      "name": "Chat (SSE stream - AGUI native)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"AGUI 裸事件测试\",\n  \"stream\": true,\n  \"protocol\": \"agui\",\n  \"user_id\": \"{{user_id}}\",\n  \"context\": {\n    \"channel\": \"web\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "SSE 流式响应，使用 bare AG-UI（AgentStreamEvent JSON 原生输出），事件类型如：\\n- run_started / step_started / step_finished\\n- text_message_start / text_message_content / text_message_end\\n- tool_call_start / tool_call_args / tool_call_end / tool_call_result\\n- custom(a2ui) / run_finished / run_error"
      }
    },
    {
      "name": "Chat (SSE stream - Enterprise AGUI)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"企业 AGUI 流式测试\",\n  \"stream\": true,\n  \"protocol\": \"enterprise\",\n  \"source_bu_type\": \"shouxian\",\n  \"app_type\": \"hcz\",\n  \"user_id\": \"{{user_id}}\",\n  \"context\": {\n    \"channel\": \"web\",\n    \"bu\": \"shouxian\",\n    \"app\": \"hcz\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "SSE 流式响应，使用企业 AGUIEnvelope 格式：\\n- 顶层: protocol=AGUI, event, id, source_bu_type, app_type\\n- data: message_id, conversation_id, ui_protocol(text/json/A2UI), ui_data"
      }
    },
    {
      "name": "Chat (SSE - Enterprise AGUI A2UI demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "text/event-stream"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"请调用 demo_a2ui_card 工具返回一个保单信息 A2UI 卡片\",\n  \"stream\": true,\n  \"protocol\": \"enterprise\",\n  \"source_bu_type\": \"shouxian\",\n  \"app_type\": \"hcz\",\n  \"user_id\": \"{{user_id}}\",\n  \"context\": {\n    \"channel\": \"web\",\n    \"bu\": \"shouxian\",\n    \"app\": \"hcz\",\n    \"force_demo_a2ui\": true\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "流式触发 DemoA2UITool，检查企业 AGUIEnvelope data.ui_protocol=\"A2UI\" 且 ui_data 为 JSON 卡片结构（包含 answerDict/result）。"
      }
    },
    {
      "name": "Chat (with idempotency key)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"帮我办理退保\",\n  \"stream\": false,\n  \"user_id\": \"{{user_id}}\",\n  \"idempotency_key\": \"req-{{$randomUUID}}\",\n  \"context\": {\n    \"policy_id\": \"POL-2024-001\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "使用幂等键防止重复请求"
      }
    },
    {
      "name": "Chat (with session)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-ark-session-key",
            "value": "{{session_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"message\": \"继续上次的对话\",\n  \"stream\": false,\n  \"user_id\": \"{{user_id}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/chat",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "通过 header 传递 session_id 继续已有会话"
      }
    },
    {
      "name": "Create session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"insurance\",\n  \"metadata\": {\n    \"user_id\": \"{{user_id}}\",\n    \"channel\": \"api_test\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions"
          ]
        }
      }
    },
    {
      "name": "Get session",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/sessions/{{session_id}}?agent_id=insurance",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}"
          ],
          "query": [
            {
              "key": "agent_id",
              "value": "insurance"
            }
          ]
        }
      }
    },
    {
      "name": "Delete session",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/sessions/{{session_id}}?agent_id=insurance",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions",
            "{{session_id}}"
          ],
          "query": [
            {
              "key": "agent_id",
              "value": "insurance"
            }
          ]
        }
      }
    },
    {
      "name": "List sessions",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/sessions?agent_id=insurance",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "sessions"
          ],
          "query": [
            {
              "key": "agent_id",
              "value": "insurance"
            }
          ]
        }
      }
    }
  ]
}

