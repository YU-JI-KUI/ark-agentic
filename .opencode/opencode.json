{
  "$schema": "https://opencode.ai/schema.json",
  "project": {
    "name": "ark-agentic",
    "description": "轻量级 ReAct Agent 框架"
  },
  "tools": {
    "formatter": "ruff",
    "linter": "ruff",
    "test": "pytest"
  },
  "commands": {
    "test": "uv run pytest -v",
    "lint": "uv run ruff check .",
    "format": "uv run ruff format .",
    "typecheck": "uv run mypy src/"
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}