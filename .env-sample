# ============================================================
# ark-agentic 环境变量
# ============================================================

# ---- 基本配置 ----
USE_GPU=true
DEV_MODE=false
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text
RAY_LOG_LEVEL=WARNING


DEFAULT_TEMPERATURE=0.3
COMPACTION_TEMPERATURE=0.3

# ---- API 服务 ----
API_HOST=0.0.0.0
API_PORT=8080

# ---- 会话持久化 ----
SESSIONS_DIR=data/ark_sessions
MEMORY_DIR=data/ark_memory

# ---- LLM 提供商选择 (pa / deepseek / openai / internal / simple_internal) ----
LLM_PROVIDER=deepseek


# ---- DeepSeek ----
DEEPSEEK_API_KEY=sk-MASK


# ---- Embedding 模型 ----
# 本地路径或 HuggingFace ID，默认 BAAI/bge-base-zh-v1.5
# EMBEDDING_MODEL_PATH=

# ---- 数据服务（policy_query / customer_info）----
# 设为 true 使用 Mock 数据（开发测试），false 或不设则调用真实服务
DATA_SERVICE_MOCK=true
DATA_SERVICE_URL=http://my-data-service
DATA_SERVICE_AUTH_URL=
DATA_SERVICE_APP_ID=
DATA_SERVICE_CLIENT_TYPE=
DATA_SERVICE_REQ_CHANNEL=
DATA_SERVICE_CLIENT_ID=
DATA_SERVICE_CLIENT_SECRET=
DATA_SERVICE_GRANT_TYPE=client_credentials

SECURITIES_SERVICE_MOCK=true

# ---- 证券服务 URL 配置 ----
# 账户总资产查询（含普通、两融账户）
SECURITIES_ACCOUNT_OVERVIEW_URL=http://test-host:3000/assetservice/restapi/getMyAllAssetsBy10

# ETF持仓查询
SECURITIES_ETF_HOLDINGS_URL=http://100.25.123.123/ais/userasset/acct/service/getUserAssetGrpHold

# 港股通持仓查询
SECURITIES_HKSC_HOLDINGS_URL=http://100.25.123.123/ais/v1/user/hksc/currentHold

# 现金资产查询
SECURITIES_CASH_ASSETS_URL=http://test.host.cn:30060/assetservice/restapi/queryCashDetail

# 基金理财持仓查询（待补充实际URL）
# SECURITIES_FUND_HOLDINGS_URL=

# 标的详情查询（待补充实际URL）
# SECURITIES_SECURITY_DETAIL_URL=