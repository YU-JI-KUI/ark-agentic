# ============================================================
# ark-agentic 环境变量
# ============================================================

# ---- 基本配置 ----
USE_GPU=true
DEV_MODE=false
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text
RAY_LOG_LEVEL=WARNING


DEFAULT_TEMPERATURE=0.3
COMPACTION_TEMPERATURE=0.3

# ---- API 服务 ----
API_HOST=0.0.0.0
API_PORT=8080

# ---- 会话持久化 ----
SESSIONS_DIR=data/ark_sessions
MEMORY_DIR=data/ark_memory

# ---- LLM (pa / openai 等，OpenAI 兼容协议) ----
# 四个公共变量（必填）
LLM_PROVIDER=openai
MODEL_NAME=gpt-4o
API_KEY=sk-MASK
# LLM_BASE_URL=https://api.openai.com/v1

# PA 模型示例（将 LLM_PROVIDER 改为 pa，并填写以下变量）:
# LLM_PROVIDER=pa
# MODEL_NAME=PA-SX-80B
# API_KEY=your-sx-api-key
# LLM_BASE_URL=https://pa-sx.example.com
# PA-SX trace 专用（可选）: PA_SX_80B_APP_ID=  PA_SX_235B_APP_ID=
# PA-JT 签名（必填）: PA_JT_OPEN_API_CODE=  PA_JT_OPEN_API_CREDENTIAL=  PA_JT_RSA_PRIVATE_KEY=  PA_JT_GPT_APP_KEY=  PA_JT_GPT_APP_SECRET=  PA_JT_SCENE_ID=


# ---- Embedding 模型 ----
# 本地路径或 HuggingFace ID，默认 BAAI/bge-base-zh-v1.5
# EMBEDDING_MODEL_PATH=

# ---- 数据服务（policy_query / customer_info）----
# 设为 true 使用 Mock 数据（开发测试），false 或不设则调用真实服务
DATA_SERVICE_MOCK=true
DATA_SERVICE_URL=http://my-data-service
DATA_SERVICE_AUTH_URL=
DATA_SERVICE_APP_ID=
DATA_SERVICE_CLIENT_TYPE=
DATA_SERVICE_REQ_CHANNEL=
DATA_SERVICE_CLIENT_ID=
DATA_SERVICE_CLIENT_SECRET=
DATA_SERVICE_GRANT_TYPE=client_credentials

SECURITIES_SERVICE_MOCK=true

# ---- 证券服务 URL 配置 ----
# 账户总资产查询（含普通、两融账户）
SECURITIES_ACCOUNT_OVERVIEW_URL=http://placeholder:3000/assetservice/restapi/getMyAllAssetsBy10

# ETF持仓查询
SECURITIES_ETF_HOLDINGS_URL=http://placeholder/ais/userasset/acct/service/getUserAssetGrpHold

# 港股通持仓查询
SECURITIES_HKSC_HOLDINGS_URL=http://placeholder/ais/v1/user/hksc/currentHold

# 现金资产查询
SECURITIES_CASH_ASSETS_URL=http://placeholder:30060/assetservice/restapi/queryCashDetail

# 营业部查询
SECURITIES_BRANCH_INFO_URL=http://placeholder/branch_info

# 基金理财持仓查询（待补充实际URL）
# SECURITIES_FUND_HOLDINGS_URL=

# 标的详情查询（待补充实际URL）
# SECURITIES_SECURITY_DETAIL_URL=