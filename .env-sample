# ============================================================
# ark-agentic 环境变量（全量，仅包含代码实际使用的变量）
# ============================================================

# ---- 应用 ----
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
ENABLE_STUDIO=false
# MCP 集成默认关闭；false 时不会初始化 MCP manager，Studio 也会隐藏 MCP tab/页面。
# 设为 true 后会挂载 agent.json 中配置的 MCP servers，并在 Studio 展示 MCP 配置入口。
ENABLE_MCP=false
AGENTS_ROOT=

# ---- Studio Auth / Users ----
# 授权数据跟随 DB_TYPE：file 模式写 data/ark_studio.json；sqlite 模式写 DB_CONNECTION_STR 指向的同一数据库。
# 逗号分隔的登录认证 provider；当前内置支持 internal，未知 provider 会跳过并记录 warning
STUDIO_AUTH_PROVIDERS=internal
# 生产环境必须设置稳定密钥；未设置时进程内临时生成，重启后 token 失效
STUDIO_AUTH_TOKEN_SECRET=
STUDIO_AUTH_TOKEN_TTL_SECONDS=43200

# ---- 会话与记忆 ----
# 后端选择：DB_TYPE=file（默认）走文件持久化；DB_TYPE=sqlite 走 SQLAlchemy + SQLite。
DB_TYPE=file

# 文件模式（DB_TYPE=file 或不设）下生效，sqlite 模式下被忽略：
SESSIONS_DIR=data/ark_sessions
MEMORY_DIR=data/ark_memory
# JOB_RUNS_DIR=data/ark_job_runs
# NOTIFICATIONS_DIR=data/ark_notifications

# SQLite 模式（DB_TYPE=sqlite）下生效：
# 路径写法：sqlite+aiosqlite:///<相对路径>  或  sqlite+aiosqlite:////<绝对路径>（注意 4 个斜杠）
# DB_CONNECTION_STR=sqlite+aiosqlite:///data/ark.db
# DB_POOL_SIZE=5

# ---- LLM（四段必填：LLM_PROVIDER, MODEL_NAME, API_KEY, LLM_BASE_URL 非 OpenAI 时必填）----
LLM_PROVIDER=openai
MODEL_NAME=gpt-4o
API_KEY=sk-MASK
LLM_BASE_URL=

# PA 模型时补充（PA-SX trace 可选；PA-JT 签名必填）
# PA_SX_80B_APP_ID=
# PA_SX_235B_APP_ID=
# PA_JT_OPEN_API_CODE=
# PA_JT_OPEN_API_CREDENTIAL=
# PA_JT_RSA_PRIVATE_KEY=
# PA_JT_GPT_APP_KEY=
# PA_JT_GPT_APP_SECRET=
# PA_JT_SCENE_ID=

# ---- 默认温度 ----
DEFAULT_TEMPERATURE=0.3

# ---- 可观测性 (OpenTelemetry tracing) ----
# TRACING controls which monitoring backends receive spans.
# Comma-separated list of: phoenix, langfuse, console, otlp
# Special value "auto" enables every provider whose credentials are set.
# Leave unset (or empty) to disable tracing entirely (NoOp tracer, zero cost).
TRACING=console

# Phoenix (set TRACING=phoenix to enable)
# PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces

# Langfuse (set TRACING=langfuse + provide credentials)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Generic OTLP (set TRACING=otlp + endpoint)
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=

# ---- 思考标签（<think>/<final> 流式区分思考态与最终回答）----
# 设为 true 时，Agent Runner 启用标签解析并在 system prompt 注入指引；enterprise 端以 REASONING_* 事件输出
# ENABLE_THINKING_TAGS=false

# ---- Embedding（记忆/检索）----
# EMBEDDING_MODEL_PATH=BAAI/bge-base-zh-v1.5

# ---- 保险数据服务（policy_query / customer_info）----
DATA_SERVICE_MOCK=true
DATA_SERVICE_URL=
DATA_SERVICE_AUTH_URL=
DATA_SERVICE_APP_ID=
DATA_SERVICE_CLIENT_TYPE=
DATA_SERVICE_REQ_CHANNEL=
DATA_SERVICE_CLIENT_ID=
DATA_SERVICE_CLIENT_SECRET=
DATA_SERVICE_GRANT_TYPE=client_credentials

# ---- 证券服务 ----
SECURITIES_SERVICE_MOCK=true
SECURITIES_ACCOUNT_TYPE=normal

SECURITIES_ACCOUNT_OVERVIEW_URL=
SECURITIES_ETF_HOLDINGS_URL=
SECURITIES_HKSC_HOLDINGS_URL=
SECURITIES_CASH_ASSETS_URL=
SECURITIES_BRANCH_INFO_URL=
SECURITIES_FUND_HOLDINGS_URL=
SECURITIES_SECURITY_DETAIL_URL=

# 可选：按服务配置鉴权（默认 header + Authorization）
# SECURITIES_ACCOUNT_OVERVIEW_AUTH_TYPE=header
# SECURITIES_ACCOUNT_OVERVIEW_AUTH_KEY=Authorization
# SECURITIES_ACCOUNT_OVERVIEW_AUTH_VALUE=Bearer xxx
