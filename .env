# ============================================================
# ark-agentic 环境变量
# ============================================================

# ---- 基本配置 ----
USE_GPU=true
DEV_MODE=false
PORT=8000
LOG_LEVEL=DEBUG
LOG_FORMAT=text
RAY_LOG_LEVEL=WARNING


DEFAULT_TEMPERATURE=0.3
COMPACTION_TEMPERATURE=0.3

# ---- API 服务 ----
API_HOST=0.0.0.0
API_PORT=8080

# ---- 会话持久化 ----
SESSIONS_DIR=data/ark_sessions
MEMORY_DIR=data/ark_memory

# ---- LLM 提供商选择 (pa / deepseek / openai / internal / simple_internal) ----
LLM_PROVIDER=deepseek
PA_MODEL=PA-SX-80B
# LLM_BASE_URL=

# ---- DeepSeek ----
DEEPSEEK_API_KEY=sk-c5958bea490a48cb80d44902c259093b

# ---- PA JT 系列 ----
# PA_JT_BASE_URL=
# PA_JT_GPT_APP_KEY=
# PA_JT_GPT_APP_SECRET=
# PA_JT_RSA_PRIVATE_KEY=
# PA_JT_OPEN_API_CODE=
# PA_JT_OPEN_API_CREDENTIAL=
# PA_JT_SCENE_ID=

# ---- PA SX 系列 ----
# PA_SX_BASE_URL=
# PA_SX_API_KEY=
# PA_SX_80B_APP_ID=
# PA_SX_235B_APP_ID=

# ---- Internal API ----
# INTERNAL_API_AUTH=
# INTERNAL_API_APPID=ark-nav

# ---- Embedding 模型 ----
# 本地路径或 HuggingFace ID，默认 BAAI/bge-base-zh-v1.5
# EMBEDDING_MODEL_PATH=

# ---- 数据服务（policy_query / customer_info）----
# 设为 true 使用 Mock 数据（开发测试），false 或不设则调用真实服务
DATA_SERVICE_MOCK=true
DATA_SERVICE_URL=http://my-data-service
DATA_SERVICE_AUTH_URL=
DATA_SERVICE_APP_ID=
DATA_SERVICE_CLIENT_TYPE=
DATA_SERVICE_REQ_CHANNEL=
DATA_SERVICE_CLIENT_ID=
DATA_SERVICE_CLIENT_SECRET=
DATA_SERVICE_GRANT_TYPE=client_credentials

SECURITIES_SERVICE_MOCK=true